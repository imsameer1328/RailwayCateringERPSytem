@{
    ViewData["Title"] = "Add New Role";
    ViewData["ActivePage"] = "Roles";
}

<!-- Page Title -->
<div class="page-title mb-4">
    <h2>Add New Role</h2>
    <p>Create a new role and assign permissions</p>
</div>

<!-- Form Card -->
<div class="table-card" style="max-width: 600px;">
    <form method="post" action="/Role/CreateRole">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Role Name</label>
            <input name="Name"
                   type="text"
                   class="form-control"
                   placeholder="e.g. Manager, Waiter"
                   required />
        </div>

        <div class="mb-3">
            <label class="form-label">Permissions</label>
            <textarea name="Permissions"
                      class="form-control"
                      rows="3"
                      placeholder="e.g. manage-orders, view-reports"></textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-purple">
                Save Role
            </button>
            <a href="/Role/GetRole" class="btn btn-light" style="border-radius:10px;">
                Cancel
            </a>
        </div>
    </form>
</div>