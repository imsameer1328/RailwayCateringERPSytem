@{
    ViewData["Title"] = "Add New Role";
    ViewData["ActivePage"] = "Roles";
}

<div class="page-title">
    <h2>Add New Role</h2>
    <p>Create a new role and assign permissions</p>
</div>

<div class="form-section">
    <form method="post" action="/Role/CreateRole">
        @Html.AntiForgeryToken()

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-tag-fill"></i> Role Name</label>
            <div class="input-group">
                <span class="input-group-text" style="background:rgba(255,138,31,0.08);border:1.5px solid rgba(0,0,0,0.08);border-radius:12px 0 0 12px;border-right:none;">
                    <i class="bi bi-person-badge" style="color:#FF8A1F;"></i>
                </span>
                <input name="Name" type="text" class="form-control" placeholder="e.g. Manager, Waiter" required
                       style="border-radius:0 12px 12px 0;" />
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-key-fill"></i> Permissions</label>
            <textarea name="Permissions" class="form-control" rows="3" placeholder="e.g. manage-orders, view-reports"></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-orange">
                <i class="bi bi-check-lg"></i> Save Role
            </button>
            <a href="/Role/GetRole" class="btn-secondary-glass">
                <i class="bi bi-x-lg"></i> Cancel
            </a>
        </div>
    </form>
</div>
