@model List<FrontRailwayCateringERP.Models.RoleViewModel>

@{
    ViewData["Title"] = "Roles Management";
    ViewData["ActivePage"] = "Roles";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-glass alert-dismissible fade show mb-4 d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="page-title">
    <h2>Roles</h2>
    <p>Manage all roles and their permissions</p>
</div>

<div class="glass-card">
    <div class="table-top">
        <span class="table-count"><i class="bi bi-database me-1"></i> Total Roles: @Model.Count</span>
        <div class="table-actions">
            <div class="table-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search roles..." id="tableSearch" />
            </div>
            <a href="/Role/CreateRole" class="btn-orange">
                <i class="bi bi-plus-lg"></i> Add New Role
            </a>
        </div>
    </div>
    <div class="table-container">
        <table class="glass-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Role Name</th>
                    <th>Permissions</th>
                    <th style="text-align:center;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <i class="bi bi-shield-exclamation"></i>
                                <p>No roles found</p>
                            </div>
                        </td>
                    </tr>
                }
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td>@(i + 1)</td>
                        <td><strong>@Model[i].Name</strong></td>
                        <td><span class="badge-orange">@Model[i].Permissions</span></td>
                        <td style="text-align:center;">
                            <a href="/Role/EditRole/@Model[i].RoleId" class="btn-icon-circle edit" title="Edit">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form method="post" action="/Role/DeleteRole/@Model[i].RoleId" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-icon-circle delete"
                                        onclick="return confirm('Are you sure you want to delete this role?')" title="Delete">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
