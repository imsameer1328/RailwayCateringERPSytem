@model FrontRailwayCateringERP.Models.RoleViewModel

@{
    ViewData["Title"] = "Edit Role";
    ViewData["ActivePage"] = "Roles";
}

<!-- Page Title -->
<div class="page-title mb-4">
    <h2>Edit Role</h2>
    <p>Update role name and permissions</p>
</div>

<!-- Form Card -->
<div class="table-card" style="max-width: 600px;">
    <form method="post" action="/Role/EditRole/@Model.RoleId">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Role Name</label>
            <input name="Name"
                   type="text"
                   class="form-control"
                   value="@Model.Name"
                   required />
        </div>

        <div class="mb-3">
            <label class="form-label">Permissions</label>
            <textarea name="Permissions"
                      class="form-control"
                      rows="3">@Model.Permissions</textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-purple">
                Update Role
            </button>
            <a href="/Role/GetRole" class="btn btn-light" style="border-radius:10px;">
                Cancel
            </a>
        </div>
    </form>
</div>