@model FrontRailwayCateringERP.Models.UserViewModel
@{
    ViewData["Title"] = "Edit User";
    ViewData["ActivePage"] = "Users";
}
<div class="page-title mb-4">
    <h2>Edit User</h2>
    <p>Update user details and role</p>
</div>
<div class="table-card" style="max-width: 600px;">
    <form method="post" action="/User/EditUser/@Model.UserId">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input name="FullName"
                   type="text"
                   class="form-control"
                   value="@Model.FullName"
                   required />
        </div>
        <div class="mb-3">
            <label class="form-label">Username</label>
            <input name="Username"
                   type="text"
                   class="form-control"
                   value="@Model.Username"
                   required />
        </div>
        <div class="mb-3">
            <label class="form-label">Phone</label>
            <input name="Phone"
                   type="text"
                   class="form-control"
                   value="@Model.Phone"
                   required />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input name="PasswordHash"
                   type="password"
                   class="form-control"
                   value="@Model.PasswordHash"
                   required />
        </div>
        <div class="mb-3">
            <label class="form-label">Role</label>
            <select name="RoleId" class="form-select" required>
                <option value="">-- Select Role --</option>
                @foreach (var role in Model.RoleList)
                {
                    <option value="@role.RoleId"
                            selected="@(role.RoleId == Model.RoleId ? "selected" : null)">
                        @role.Name
                    </option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Status</label>
            <select name="Status" class="form-select">
                <option value="Active" selected="@(Model.Status == "Active" ? "selected" : null)">Active</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive" ? "selected" : null)">Inactive</option>
            </select>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-purple">Update User</button>
            <a href="/User/GetUser" class="btn btn-light" style="border-radius:10px;">Cancel</a>
        </div>
    </form>
</div>