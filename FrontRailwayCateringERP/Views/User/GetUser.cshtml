@model List<FrontRailwayCateringERP.Models.UserViewModel>
@{
    ViewData["Title"] = "Users Management";
    ViewData["ActivePage"] = "Users";
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-glass alert-dismissible fade show mb-4 d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="page-title">
    <h2>Users</h2>
    <p>Manage all system users and their roles</p>
</div>
<div class="glass-card">
    <div class="table-top">
        <span class="table-count"><i class="bi bi-database me-1"></i> Total Users: @Model.Count</span>
        <div class="table-actions">
            <div class="table-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search users..." />
            </div>
            <a href="/User/CreateUser" class="btn-orange">
                <i class="bi bi-plus-lg"></i> Add New User
            </a>
        </div>
    </div>
    <div class="table-container">
        <table class="glass-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Username</th>
                    <th>Phone</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th style="text-align:center;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="7"><div class="empty-state"><i class="bi bi-people"></i><p>No users found</p></div></td></tr>
                }
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td>@(i + 1)</td>
                        <td><strong>@Model[i].FullName</strong></td>
                        <td>@Model[i].Username</td>
                        <td>@Model[i].Phone</td>
                        <td><span class="badge-orange">@Model[i].Role?.Name</span></td>
                        <td>
                            @if (Model[i].Status == "Active")
                            {
                                <span class="badge-green">Active</span>
                            }
                            else
                            {
                                <span class="badge-red">Inactive</span>
                            }
                        </td>
                        <td style="text-align:center;">
                            <a href="/User/EditUser/@Model[i].UserId" class="btn-icon-circle edit" title="Edit">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form method="post" action="/User/DeleteUser/@Model[i].UserId" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-icon-circle delete"
                                        onclick="return confirm('Are you sure you want to delete this user?')" title="Delete">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
