@model List<FrontRailwayCateringERP.Models.UserViewModel>
@{
    ViewData["Title"] = "Users Management";
    ViewData["ActivePage"] = "Users";
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        ⚠️ @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<!-- Page Title -->
<div class="page-title mb-4">
    <h2>Users</h2>
    <p>Manage all system users and their roles</p>
</div>
<!-- Table Card -->
<div class="table-card">
    <!-- Top Bar -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span style="font-size:14px; font-weight:600; color:#666;">
            Total Users: @Model.Count
        </span>
        <a href="/User/CreateUser" class="btn btn-purple">
            + Add New User
        </a>
    </div>
    <!-- Table -->
    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Username</th>
                <th>Phone</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        No users found
                    </td>
                </tr>
            }
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr>
                    <td>@(i + 1)</td>
                    <td><strong>@Model[i].FullName</strong></td>
                    <td style="color:#666;">@Model[i].Username</td>
                    <td style="color:#666;">@Model[i].Phone</td>
                    <td style="color:#666;">@Model[i].Role?.Name</td>
                    <td>
                        @if (Model[i].Status == "Active")
                        {
                            <span class="badge-active">Active</span>
                        }
                        else
                        {
                            <span class="badge-inactive">Inactive</span>
                        }
                    </td>
                    <td>
                        <a href="/User/EditUser/@Model[i].UserId" class="btn btn-edit me-1">
                            ✏️
                        </a>
                        <form method="post" action="/User/DeleteUser/@Model[i].UserId"
                              style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-delete"
                                    onclick="return confirm('Are you sure you want to delete this user?')">
                                🗑️
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>