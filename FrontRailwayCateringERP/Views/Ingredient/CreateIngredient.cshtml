@{
    ViewData["Title"] = "Add New Ingredient";
    ViewData["ActivePage"] = "Ingredients";
}

<div class="page-title">
    <h2>Add New Ingredient</h2>
    <p>Add a new ingredient with stock details</p>
</div>

<div class="form-section">
    <form method="post" action="/Ingredient/CreateIngredient">
        @Html.AntiForgeryToken()

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-tag-fill"></i> Ingredient Name</label>
            <div class="input-group">
                <span class="input-group-text" style="background:rgba(255,138,31,0.08);border:1.5px solid rgba(0,0,0,0.08);border-radius:12px 0 0 12px;border-right:none;">
                    <i class="bi bi-basket" style="color:#FF8A1F;"></i>
                </span>
                <input name="Name" type="text" class="form-control" placeholder="e.g. Chicken, Flour, Oil" required
                       style="border-radius:0 12px 12px 0;" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-4">
                <label class="form-label"><i class="bi bi-box-seam-fill"></i> Current Stock</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:rgba(255,138,31,0.08);border:1.5px solid rgba(0,0,0,0.08);border-radius:12px 0 0 12px;border-right:none;">
                        <i class="bi bi-bar-chart" style="color:#FF8A1F;"></i>
                    </span>
                    <input name="CurrentStock" type="number" step="0.01" class="form-control" placeholder="0.00" required
                           style="border-radius:0 12px 12px 0;" />
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <label class="form-label"><i class="bi bi-exclamation-triangle-fill"></i> Minimum Threshold</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:rgba(255,138,31,0.08);border:1.5px solid rgba(0,0,0,0.08);border-radius:12px 0 0 12px;border-right:none;">
                        <i class="bi bi-arrow-down" style="color:#FF8A1F;"></i>
                    </span>
                    <input name="MinimumThreshold" type="number" step="0.01" class="form-control" placeholder="0.00" required
                           style="border-radius:0 12px 12px 0;" />
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <label class="form-label"><i class="bi bi-rulers"></i> Unit</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:rgba(255,138,31,0.08);border:1.5px solid rgba(0,0,0,0.08);border-radius:12px 0 0 12px;border-right:none;">
                        <i class="bi bi-graph-up" style="color:#FF8A1F;"></i>
                    </span>
                    <input name="Unit" type="text" class="form-control" placeholder="e.g. kg, liters, pieces" required
                           style="border-radius:0 12px 12px 0;" />
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-orange">
                <i class="bi bi-check-lg"></i> Save Ingredient
            </button>
            <a href="/Ingredient/GetIngredient" class="btn-secondary-glass">
                <i class="bi bi-x-lg"></i> Cancel
            </a>
        </div>
    </form>
</div>
