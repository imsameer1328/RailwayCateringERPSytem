@model List<FrontRailwayCateringERP.Models.IngredientViewModel>

@{
    ViewData["Title"] = "Ingredients Management";
    ViewData["ActivePage"] = "Ingredients";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-glass alert-dismissible fade show mb-4 d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="page-title">
    <h2>Ingredients</h2>
    <p>Manage stock levels and ingredient details</p>
</div>

<div class="glass-card">
    <div class="table-top">
        <span class="table-count"><i class="bi bi-database me-1"></i> Total Ingredients: @Model.Count</span>
        <div class="table-actions">
            <div class="table-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search ingredients..." id="tableSearch" />
            </div>
            <a href="/Ingredient/CreateIngredient" class="btn-orange">
                <i class="bi bi-plus-lg"></i> Add New Ingredient
            </a>
        </div>
    </div>
    <div class="table-container">
        <table class="glass-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Current Stock</th>
                    <th>Min Threshold</th>
                    <th>Unit</th>
                    <th>Status</th>
                    <th style="text-align:center;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-basket"></i>
                                <p>No ingredients found</p>
                            </div>
                        </td>
                    </tr>
                }
                @for (int i = 0; i < Model.Count; i++)
                {
                    var isLow = Model[i].CurrentStock < Model[i].MinimumThreshold;
                    <tr class="@(isLow ? "table-danger-row" : "")">
                        <td>@(i + 1)</td>
                        <td><strong>@Model[i].Name</strong></td>
                        <td>@Model[i].CurrentStock</td>
                        <td>@Model[i].MinimumThreshold</td>
                        <td>@Model[i].Unit</td>
                        <td>
                            @if (isLow)
                            {
                                <span class="badge-red"><i class="bi bi-exclamation-triangle-fill"></i> Low Stock</span>
                            }
                            else
                            {
                                <span class="badge-green"><i class="bi bi-check-circle-fill"></i> In Stock</span>
                            }
                        </td>
                        <td style="text-align:center;">
                            <a href="/Ingredient/EditIngredient/@Model[i].IngredientId" class="btn-icon-circle edit" title="Edit">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form method="post" action="/Ingredient/DeleteIngredient/@Model[i].IngredientId" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-icon-circle delete"
                                        onclick="return confirm('Are you sure you want to delete this ingredient?')" title="Delete">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
