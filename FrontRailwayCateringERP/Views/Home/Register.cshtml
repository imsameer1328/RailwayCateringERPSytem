@model FrontRailwayCateringERP.Models.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Railway Catering ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: #FFF7EE;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
        body::before {
            content: '';
            position: fixed;
            top: -20%;
            right: -10%;
            width: 700px;
            height: 700px;
            background: radial-gradient(circle, rgba(255,138,31,0.15) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        body::after {
            content: '';
            position: fixed;
            bottom: -15%;
            left: -5%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(255,180,92,0.2) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        .register-container {
            width: 100%;
            max-width: 440px;
            padding: 20px;
            position: relative;
            z-index: 1;
        }
        .register-card {
            background: rgba(255,255,255,0.72);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.35);
            border-radius: 24px;
            padding: 36px 32px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.06);
        }
        .register-logo {
            text-align: center;
            margin-bottom: 28px;
        }
        .register-logo .logo-icon {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            background: linear-gradient(135deg, #FF8A1F, #FFB45C);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 24px;
            color: white;
            box-shadow: 0 4px 20px rgba(255,138,31,0.3);
        }
        .register-logo h2 {
            font-size: 20px;
            font-weight: 800;
            color: #2B2B2B;
            margin: 0;
            letter-spacing: -0.5px;
        }
        .register-logo p {
            font-size: 13px;
            color: #999;
            margin-top: 4px;
        }
        .input-group-custom {
            position: relative;
            margin-bottom: 14px;
        }
        .input-group-custom .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #bbb;
            font-size: 16px;
            z-index: 2;
        }
        .input-group-custom input {
            border: 1.5px solid rgba(0,0,0,0.08);
            border-radius: 12px;
            font-size: 13px;
            padding: 11px 16px 11px 42px;
            font-family: 'Inter', sans-serif;
            background: rgba(255,255,255,0.8);
            transition: all 0.25s ease;
            width: 100%;
            outline: none;
        }
        .input-group-custom input:focus {
            border-color: #FF8A1F;
            box-shadow: 0 0 0 4px rgba(255,138,31,0.1);
            background: white;
        }
        .input-group-custom input::placeholder { color: #ccc; }
        .btn-register {
            background: linear-gradient(135deg, #FF8A1F, #FFB45C);
            color: white;
            border: none;
            border-radius: 30px;
            padding: 12px 22px;
            font-weight: 700;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            box-shadow: 0 4px 14px rgba(255,138,31,0.3);
            transition: all 0.25s ease;
            width: 100%;
            cursor: pointer;
            margin-top: 4px;
        }
        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(255,138,31,0.4);
        }
        .alert-error {
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.15);
            border-radius: 12px;
            color: #EF4444;
            font-size: 13px;
            padding: 12px 16px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .register-footer {
            text-align: center;
            margin-top: 20px;
            font-size: 13px;
            color: #999;
        }
        .register-footer a {
            color: #FF8A1F;
            font-weight: 600;
            text-decoration: none;
        }
        .register-footer a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="register-card">
            <div class="register-logo">
                <div class="logo-icon"><i class="bi bi-shield-plus"></i></div>
                <h2>Setup Super Admin</h2>
                <p>Create the first administrator account</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert-error">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post" action="/Home/Register">
                @Html.AntiForgeryToken()
                <div class="input-group-custom">
                    <i class="bi bi-person input-icon"></i>
                    <input name="FullName" type="text" placeholder="Full Name" required value="@Model.FullName" />
                </div>
                <div class="input-group-custom">
                    <i class="bi bi-person-badge input-icon"></i>
                    <input name="Username" type="text" placeholder="Username" required value="@Model.Username" />
                </div>
                <div class="input-group-custom">
                    <i class="bi bi-telephone input-icon"></i>
                    <input name="Phone" type="text" placeholder="Phone (optional)" value="@Model.Phone" />
                </div>
                <div class="input-group-custom">
                    <i class="bi bi-lock input-icon"></i>
                    <input name="Password" type="password" placeholder="Password (min 6 chars)" required />
                </div>
                <div class="input-group-custom">
                    <i class="bi bi-lock-fill input-icon"></i>
                    <input name="ConfirmPassword" type="password" placeholder="Confirm Password" required />
                </div>
                <button type="submit" class="btn-register">
                    <i class="bi bi-shield-check"></i> Create Super Admin
                </button>
            </form>

            <div class="register-footer">
                Already have an account? <a href="/Home/Login">Sign In</a>
            </div>
        </div>
    </div>
</body>
</html>
