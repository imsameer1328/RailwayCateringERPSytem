@model FrontRailwayCateringERP.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Railway Catering ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: #FFF7EE;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
        body::before {
            content: '';
            position: fixed;
            top: -20%;
            right: -10%;
            width: 700px;
            height: 700px;
            background: radial-gradient(circle, rgba(255,138,31,0.15) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        body::after {
            content: '';
            position: fixed;
            bottom: -15%;
            left: -5%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(255,180,92,0.2) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        .login-container {
            width: 100%;
            max-width: 420px;
            padding: 20px;
            position: relative;
            z-index: 1;
        }
        .login-card {
            background: rgba(255,255,255,0.72);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.35);
            border-radius: 24px;
            padding: 40px 32px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.06);
        }
        .login-logo {
            text-align: center;
            margin-bottom: 32px;
        }
        .login-logo .logo-icon {
            width: 64px;
            height: 64px;
            border-radius: 18px;
            background: linear-gradient(135deg, #FF8A1F, #FFB45C);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 14px;
            font-size: 28px;
            color: white;
            box-shadow: 0 4px 20px rgba(255,138,31,0.3);
        }
        .login-logo h2 {
            font-size: 22px;
            font-weight: 800;
            color: #2B2B2B;
            margin: 0;
            letter-spacing: -0.5px;
        }
        .login-logo p {
            font-size: 13px;
            color: #999;
            margin-top: 4px;
        }
        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: #555;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .form-label i { color: #FF8A1F; font-size: 14px; }
        .input-group-custom {
            position: relative;
            margin-bottom: 18px;
        }
        .input-group-custom .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #bbb;
            font-size: 16px;
            z-index: 2;
        }
        .input-group-custom input {
            border: 1.5px solid rgba(0,0,0,0.08);
            border-radius: 12px;
            font-size: 13px;
            padding: 12px 16px 12px 42px;
            font-family: 'Inter', sans-serif;
            background: rgba(255,255,255,0.8);
            transition: all 0.25s ease;
            width: 100%;
            outline: none;
        }
        .input-group-custom input:focus {
            border-color: #FF8A1F;
            box-shadow: 0 0 0 4px rgba(255,138,31,0.1);
            background: white;
        }
        .input-group-custom input::placeholder { color: #ccc; }
        .btn-login {
            background: linear-gradient(135deg, #FF8A1F, #FFB45C);
            color: white;
            border: none;
            border-radius: 30px;
            padding: 12px 22px;
            font-weight: 700;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            box-shadow: 0 4px 14px rgba(255,138,31,0.3);
            transition: all 0.25s ease;
            width: 100%;
            cursor: pointer;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(255,138,31,0.4);
        }
        .alert-error {
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.15);
            border-radius: 12px;
            color: #EF4444;
            font-size: 13px;
            padding: 12px 16px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .login-footer {
            text-align: center;
            margin-top: 24px;
            font-size: 12px;
            color: #bbb;
        }
        .login-footer strong { color: #FF8A1F; }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="login-logo">
                <div class="logo-icon"><i class="bi bi-train-front"></i></div>
                <h2>RailERP</h2>
                <p>Railway Catering Management System</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert-error">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post" action="/Home/Login">
                @Html.AntiForgeryToken()
                <div class="input-group-custom">
                    <i class="bi bi-person input-icon"></i>
                    <input name="Username" type="text" placeholder="Username" required value="@Model.Username" />
                </div>
                <div class="input-group-custom">
                    <i class="bi bi-lock input-icon"></i>
                    <input name="Password" type="password" placeholder="Password" required />
                </div>
                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </button>
            </form>

            @if (ViewBag.UsersExist != null && !ViewBag.UsersExist)
            {
            <div class="register-footer" style="text-align:center;margin-top:20px;font-size:13px;color:#999;">
                No account yet? <a href="/Home/Register" style="color:#FF8A1F;font-weight:600;text-decoration:none;">Setup Super Admin</a>
            </div>
            }

            <div class="login-footer">
                <strong>Railway Catering ERP</strong> Version 1.0
            </div>
        </div>
    </div>
</body>
</html>
