@model FrontRailwayCateringERP.Models.JourneyViewModel

@{
    ViewData["Title"] = "Edit Journey";
    ViewData["ActivePage"] = "Journeys";
}

<div class="page-title">
    <h2>Edit Journey</h2>
    <p>Update journey schedule, route, and assignment</p>
</div>

<div class="form-section">
    <form method="post" action="/Journey/EditJourney/@Model.JourneyId">
        @Html.AntiForgeryToken()

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-calendar-event-fill"></i> Journey Date</label>
            <input name="JourneyDate" type="date" class="form-control" value="@Model.JourneyDate.ToString("yyyy-MM-dd")" required />
        </div>

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-clock-fill"></i> Departure Time</label>
            <input name="DepartureTime" type="time" class="form-control" value="@Model.DepartureTime.ToString("HH:mm")" required />
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label class="form-label"><i class="bi bi-geo-alt-fill"></i> Origin</label>
                <input name="Origin" type="text" class="form-control" value="@Model.Origin" required />
            </div>
            <div class="col-md-6">
                <label class="form-label"><i class="bi bi-geo-alt-fill"></i> Destination</label>
                <input name="Destination" type="text" class="form-control" value="@Model.Destination" required />
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-train-front-fill"></i> Train</label>
            <select name="TrainId" class="form-select" required>
                <option value="">-- Select Train --</option>
                @foreach (var train in Model.TrainList)
                {
                    <option value="@train.TrainId" selected="@(train.TrainId == Model.TrainId ? "selected" : null)">@train.TrainName (@train.TrainNumber)</option>
                }
            </select>
        </div>

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-person-badge-fill"></i> Manager</label>
            <select name="ManagerId" class="form-select" required>
                <option value="">-- Select Manager --</option>
                @foreach (var user in Model.UserList)
                {
                    <option value="@user.UserId" selected="@(user.UserId == Model.ManagerId ? "selected" : null)">@user.FullName</option>
                }
            </select>
        </div>

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-flag-fill"></i> Status</label>
            <select name="Status" class="form-select">
                <option value="Scheduled" selected="@(Model.Status == "Scheduled" ? "selected" : null)">Scheduled</option>
                <option value="InProgress" selected="@(Model.Status == "InProgress" ? "selected" : null)">In Progress</option>
                <option value="Completed" selected="@(Model.Status == "Completed" ? "selected" : null)">Completed</option>
                <option value="Cancelled" selected="@(Model.Status == "Cancelled" ? "selected" : null)">Cancelled</option>
            </select>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-orange"><i class="bi bi-check-lg"></i> Update Journey</button>
            <a href="/Journey/GetJourney" class="btn-secondary-glass"><i class="bi bi-x-lg"></i> Cancel</a>
        </div>
    </form>
</div>
