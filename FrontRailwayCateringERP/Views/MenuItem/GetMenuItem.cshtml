@model List<FrontRailwayCateringERP.Models.MenuItemViewModel>

@{
    ViewData["Title"] = "Menu Items Management";
    ViewData["ActivePage"] = "MenuItems";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="page-title mb-4">
    <h2>Menu Items</h2>
    <p>Manage all menu items and their details</p>
</div>

<div class="table-card">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <span style="font-size:14px; font-weight:600; color:#666;">
            Total Menu Items: @Model.Count
        </span>
        <a href="/MenuItem/CreateMenuItem" class="btn btn-purple">
            + Add New Menu Item
        </a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        No menu items found
                    </td>
                </tr>
            }
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr>
                    <td>@(i + 1)</td>
                    <td><strong>@Model[i].Name</strong></td>
                    <td style="color:#666;">@Model[i].Category</td>
                    <td>@Model[i].Price.ToString("C")</td>
                    <td>
                        <span class="badge @(Model[i].AvailabilityStatus == "Available" ? "bg-success" : "bg-warning")">
                            @Model[i].AvailabilityStatus
                        </span>
                    </td>
                    <td>
                        <a href="/MenuItem/EditMenuItem/@Model[i].MenuItemId" class="btn btn-edit me-1">
                            ✏️
                        </a>
                        <form method="post" action="/MenuItem/DeleteMenuItem/@Model[i].MenuItemId"
                              style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-delete"
                                    onclick="return confirm('Are you sure you want to delete this menu item?')">
                                🗑️
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
