@{
    ViewData["Title"] = "Add New Menu Item";
    ViewData["ActivePage"] = "MenuItems";
}

<div class="page-title mb-4">
    <h2>Add New Menu Item</h2>
    <p>Create a new menu item with pricing and availability</p>
</div>

<div class="table-card" style="max-width: 600px;">
    <form method="post" action="/MenuItem/CreateMenuItem">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Item Name</label>
            <input name="Name"
                   type="text"
                   class="form-control"
                   placeholder="e.g. Chicken Biryani, Tea"
                   required />
        </div>

        <div class="mb-3">
            <label class="form-label">Category</label>
            <input name="Category"
                   type="text"
                   class="form-control"
                   placeholder="e.g. Main Course, Beverage, Snack"
                   required />
        </div>

        <div class="mb-3">
            <label class="form-label">Price</label>
            <input name="Price"
                   type="number"
                   step="0.01"
                   class="form-control"
                   placeholder="e.g. 250.00"
                   required />
        </div>

        <div class="mb-3">
            <label class="form-label">Availability Status</label>
            <select name="AvailabilityStatus" class="form-control">
                <option value="Available">Available</option>
                <option value="Unavailable">Unavailable</option>
            </select>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-purple">
                Save Menu Item
            </button>
            <a href="/MenuItem/GetMenuItem" class="btn btn-light" style="border-radius:10px;">
                Cancel
            </a>
        </div>
    </form>
</div>
