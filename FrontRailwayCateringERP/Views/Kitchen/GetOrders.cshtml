@model List<FrontRailwayCateringERP.Models.OrderViewModel>
@{
    ViewData["Title"] = "Kitchen Orders";
    ViewData["ActivePage"] = "Kitchen";
}
<div class="page-title">
    <h2>Kitchen Orders</h2>
    <p>Prepare items and mark them ready for pickup</p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert-glass" style="margin-bottom:18px;">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}

@{
    var readyOrders = Model.Where(o => o.OrderItems.All(i => i.KitchenStatus != "Pending" && i.KitchenStatus != "Cooking") && o.OrderItems.Any(i => i.KitchenStatus == "Ready"));
    var cookingOrders = Model.Where(o => o.OrderItems.Any(i => i.KitchenStatus == "Pending" || i.KitchenStatus == "Cooking"));
}

@if (readyOrders.Any())
{
    <h4 style="font-size:14px;color:#22C55E;font-weight:700;margin:0 0 12px 0;display:flex;align-items:center;gap:8px;">
        <i class="bi bi-hand-index-thumb"></i> Ready for Pickup
    </h4>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:16px;margin-bottom:28px;">
        @foreach (var order in readyOrders)
        {
            <div class="kitchen-card ready-card">
                <div class="kc-header">
                    <div>
                        <strong style="font-size:15px;color:#2B2B2B;">#@order.OrderId.ToString().Substring(0, 8)</strong>
                        <div style="font-size:12px;color:#999;margin-top:2px;">Coach @order.CoachNumber · Seat @order.SeatNumber</div>
                    </div>
                    <span style="font-size:11px;color:#bbb;">@order.CreatedAt.ToString("MMM dd, HH:mm")</span>
                </div>
                <div style="padding:14px 18px;">
                    @foreach (var item in order.OrderItems)
                    {
                        <div class="kc-item">
                            <div style="flex:1;">
                                <div style="font-weight:600;font-size:13px;color:#2B2B2B;display:flex;align-items:center;gap:6px;">
                                    @item.MenuItem?.Name
                                    @if (item.KitchenStatus == "Ready")
                                    {
                                        <span class="badge-green" style="font-size:9px;">READY</span>
                                    }
                                </div>
                                <div style="font-size:12px;color:#999;">Qty: @item.Quantity</div>
                            </div>
                            <span class="badge-@(item.KitchenStatus == "Pending" ? "orange" : item.KitchenStatus == "Cooking" ? "blue" : "green")" style="font-size:10px;">
                                @item.KitchenStatus
                            </span>
                        </div>
                    }
                </div>
                <div class="kc-footer" style="color:#22C55E;">
                    <i class="bi bi-check-circle-fill"></i> Waiting for waiter to pick up
                </div>
            </div>
        }
    </div>
}

@if (cookingOrders.Any())
{
    <h4 style="font-size:14px;color:#FF8A1F;font-weight:600;margin:0 0 12px 0;display:flex;align-items:center;gap:8px;">
        <i class="bi bi-fire"></i> In Progress
    </h4>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:16px;">
        @foreach (var order in cookingOrders)
        {
            <div class="kitchen-card">
                <div class="kc-header">
                    <div>
                        <strong style="font-size:15px;color:#2B2B2B;">#@order.OrderId.ToString().Substring(0, 8)</strong>
                        <div style="font-size:12px;color:#999;margin-top:2px;">Coach @order.CoachNumber · Seat @order.SeatNumber</div>
                    </div>
                    <span class="badge-orange">@order.OrderItems.Count(i => i.KitchenStatus == "Pending" || i.KitchenStatus == "Cooking") left</span>
                </div>
                <div style="padding:14px 18px;">
                    <div style="font-size:11px;color:#bbb;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">Order Items</div>
                    @foreach (var item in order.OrderItems)
                    {
                        <div class="kc-item">
                            <div style="flex:1;">
                                <div style="font-weight:600;font-size:13px;color:#2B2B2B;">@item.MenuItem?.Name</div>
                                <div style="font-size:12px;color:#999;">Qty: @item.Quantity</div>
                            </div>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <span class="badge-@(item.KitchenStatus == "Pending" ? "orange" : item.KitchenStatus == "Cooking" ? "blue" : "green")" style="font-size:10px;">
                                    @item.KitchenStatus
                                </span>
                                @if (item.KitchenStatus == "Pending")
                                {
                                    <form method="post" action="/Kitchen/UpdateItemStatus" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@item.OrderItemId" />
                                        <input type="hidden" name="status" value="Cooking" />
                                        <button type="submit" class="btn-icon-circle edit" title="Accept"><i class="bi bi-check-lg"></i></button>
                                    </form>
                                }
                                @if (item.KitchenStatus == "Cooking")
                                {
                                    <form method="post" action="/Kitchen/UpdateItemStatus" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@item.OrderItemId" />
                                        <input type="hidden" name="status" value="Ready" />
                                        <button type="submit" class="btn-icon-circle view" title="Mark Ready"><i class="bi bi-hand-thumbs-up"></i></button>
                                    </form>
                                }
                                @if (item.KitchenStatus == "Ready")
                                {
                                    <span style="font-size:16px;color:#22C55E;"><i class="bi bi-check-circle-fill"></i></span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="kc-footer">
                    <i class="bi bi-person"></i> @order.User?.FullName
                    <span style="margin-left:auto;font-size:12px;color:#bbb;">@order.CreatedAt.ToString("MMM dd, HH:mm")</span>
                </div>
            </div>
        }
    </div>
}

@if (!cookingOrders.Any() && !readyOrders.Any())
{
    <div class="glass-card">
        <div class="empty-state">
            <i class="bi bi-check2-circle" style="color:#22C55E;font-size:48px;"></i>
            <p style="color:#999;font-size:14px;margin-top:8px;">All caught up! No pending orders.</p>
        </div>
    </div>
}

<style>
    .kitchen-card {
        background: rgba(255,255,255,0.72);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.35);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0,0,0,0.05);
        transition: all 0.25s ease;
    }
    .kitchen-card:hover {
        box-shadow: 0 12px 40px rgba(255,138,31,0.1);
    }
    .kitchen-card.ready-card {
        border-left: 4px solid #22C55E;
        background: rgba(34,197,94,0.04);
    }
    .kc-header {
        padding: 14px 18px;
        border-bottom: 1px solid rgba(0,0,0,0.04);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .kc-item {
        display: flex;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid rgba(0,0,0,0.03);
        gap: 10px;
    }
    .kc-item:last-child { border-bottom: none; }
    .kc-footer {
        padding: 10px 18px;
        border-top: 1px solid rgba(0,0,0,0.04);
        font-size: 12px;
        color: #999;
        display: flex;
        align-items: center;
        gap: 6px;
    }
</style>
