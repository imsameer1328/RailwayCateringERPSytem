@{
    ViewData["Title"] = "Add New Train";
    ViewData["ActivePage"] = "Trains";
}

<div class="page-title">
    <h2>Add New Train</h2>
    <p>Create a new train and define its details</p>
</div>

<div class="form-section">
    <form method="post" action="/Train/CreateTrain">
        @Html.AntiForgeryToken()

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-train-front-fill"></i> Train Name</label>
            <div class="input-group">
                <span class="input-group-text" style="background:rgba(255,138,31,0.08);border:1.5px solid rgba(0,0,0,0.08);border-radius:12px 0 0 12px;border-right:none;">
                    <i class="bi bi-train-front" style="color:#FF8A1F;"></i>
                </span>
                <input name="TrainName" type="text" class="form-control" placeholder="e.g. Green Line Express" required style="border-radius:0 12px 12px 0;" />
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-hash"></i> Train Number</label>
            <div class="input-group">
                <span class="input-group-text" style="background:rgba(255,138,31,0.08);border:1.5px solid rgba(0,0,0,0.08);border-radius:12px 0 0 12px;border-right:none;">
                    <i class="bi bi-123" style="color:#FF8A1F;"></i>
                </span>
                <input name="TrainNumber" type="text" class="form-control" placeholder="e.g. 101A" required style="border-radius:0 12px 12px 0;" />
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label"><i class="bi bi-layers-fill"></i> Total Coaches</label>
            <div class="input-group">
                <span class="input-group-text" style="background:rgba(255,138,31,0.08);border:1.5px solid rgba(0,0,0,0.08);border-radius:12px 0 0 12px;border-right:none;">
                    <i class="bi bi-grid-3x3" style="color:#FF8A1F;"></i>
                </span>
                <input name="TotalCoaches" type="number" class="form-control" placeholder="e.g. 20" required style="border-radius:0 12px 12px 0;" />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-orange"><i class="bi bi-check-lg"></i> Save Train</button>
            <a href="/Train/GetTrain" class="btn-secondary-glass"><i class="bi bi-x-lg"></i> Cancel</a>
        </div>
    </form>
</div>
