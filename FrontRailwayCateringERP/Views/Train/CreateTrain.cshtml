@{
    ViewData["Title"] = "Add New Train";
    ViewData["ActivePage"] = "Trains";
}

<!-- Page Title -->
<div class="page-title mb-4">
    <h2>Add New Train</h2>
    <p>Create a new train and define its details</p>
</div>

<!-- Form Card -->
<div class="table-card" style="max-width: 600px;">
    <form method="post" action="/Train/CreateTrain">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Train Name</label>
            <input name="TrainName"
                   type="text"
                   class="form-control"
                   placeholder="e.g. Green Line Express"
                   required />
        </div>

        <div class="mb-3">
            <label class="form-label">Train Number</label>
            <input name="TrainNumber"
                   type="text"
                   class="form-control"
                   placeholder="e.g. 101A"
                   required />
        </div>

        <div class="mb-3">
            <label class="form-label">Total Coaches</label>
            <input name="TotalCoaches"
                   type="number"
                   class="form-control"
                   placeholder="e.g. 20"
                   required />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-purple">
                Save Train
            </button>
            <a href="/Train/GetTrain" class="btn btn-light" style="border-radius:10px;">
                Cancel
            </a>
        </div>
    </form>
</div>
