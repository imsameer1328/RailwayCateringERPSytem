@model FrontRailwayCateringERP.Models.TrainViewModel

@{
    ViewData["Title"] = "Edit Train";
    ViewData["ActivePage"] = "Trains";
}

<!-- Page Title -->
<div class="page-title mb-4">
    <h2>Edit Train</h2>
    <p>Update train details such as name, number, and coaches</p>
</div>

<!-- Form Card -->
<div class="table-card" style="max-width: 600px;">
    <form method="post" action="/Train/EditTrain/@Model.TrainId">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Train Name</label>
            <input name="TrainName"
                   type="text"
                   class="form-control"
                   value="@Model.TrainName"
                   required />
        </div>

        <div class="mb-3">
            <label class="form-label">Train Number</label>
            <input name="TrainNumber"
                   type="text"
                   class="form-control"
                   value="@Model.TrainNumber"
                   required />
        </div>

        <div class="mb-3">
            <label class="form-label">Total Coaches</label>
            <input name="TotalCoaches"
                   type="number"
                   class="form-control"
                   value="@Model.TotalCoaches"
                   required />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-purple">
                Update Train
            </button>
            <a href="/Train/GetTrain" class="btn btn-light" style="border-radius:10px;">
                Cancel
            </a>
        </div>
    </form>
</div>
