<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - Railway Catering ERP</title>

	<!-- Bootstrap CSS -->
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

	<!-- Bootstrap Icons -->
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

	<style>
		body {
			min-height: 100vh;
			background: #F4F6FB;
			font-family: 'Segoe UI', sans-serif;
			margin: 0;
			padding: 0;
		}

		/* ── Sidebar ── */
		.sidebar {
			width: 220px;
			min-width: 220px;
			background: white;
			border-right: 1px solid #EBEBF0;
			box-shadow: 4px 0 20px rgba(0,0,0,0.04);
			display: flex;
			flex-direction: column;
			min-height: 100vh;
			position: sticky;
			top: 0;
			align-self: flex-start;
			height: 100vh;
			overflow-y: auto;
		}

		.sidebar-brand {
			padding: 10px;
			background: linear-gradient(135deg, #6C22C9, #8B47E8);
			color: white;
			text-decoration: none;
			display: block;
		}

			.sidebar-brand h5 {
				margin: 0;
				font-weight: 700;
				font-size: 16px;
				color: white;
			}

			.sidebar-brand small {
				opacity: 0.75;
				font-size: 11px;
				color: white;
			}

		.sidebar-nav {
			padding: 10px 12px;
			flex: 1;
			display: flex;
			flex-direction: column;
			justify-content: flex-start;
			gap: 4px;
		}

			.sidebar-nav .nav-link {
				color: #666;
				font-size: 14px;
				font-weight: 500;
				padding: 10px 14px;
				border-radius: 10px;
				display: flex;
				align-items: center;
				gap: 10px;
				transition: all 0.2s;
				text-decoration: none;
			}

				.sidebar-nav .nav-link:hover {
					background: #F3EEFF;
					color: #6C22C9;
				}

				.sidebar-nav .nav-link.active {
					background: linear-gradient(135deg, #6C22C9, #8B47E8);
					color: white;
					font-weight: 600;
					box-shadow: 0 4px 12px rgba(108,34,201,0.3);
				}

		.sidebar-footer {
			padding: 14px 20px;
			border-top: 1px solid #EBEBF0;
			font-size: 11px;
			color: #bbb;
			line-height: 1.8;
		}

		/* ── Main Content ── */
		.main-wrapper {
			flex: 1;
			display: flex;
			flex-direction: column;
			min-height: 100vh;
			background: #F4F6FB;
		}

		/* ── Top Header ── */
		.top-header {
			background: linear-gradient(135deg, #6C22C9, #8B47E8);
			color: white;
			padding: 14px 28px;
			display: flex;
			justify-content: space-between;
			align-items: center;
			box-shadow: 0 4px 20px rgba(108,34,201,0.3);
			position: sticky;
			top: 0;
			z-index: 99;
		}

			.top-header h5 {
				margin: 0;
				font-weight: 700;
				font-size: 18px;
				color: white;
			}

		/* ── Content Area ── */
		.content-area {
			padding: 28px 32px;
			flex: 1;
			width: 100%;
		}

		/* ── Page Title ── */
		.page-title h2 {
			font-size: 22px;
			font-weight: 700;
			color: #1a1a2e;
		}

		.page-title p {
			font-size: 13px;
			color: #888;
			margin-top: 2px;
		}

		/* ── Table Card ── */
		.table-card {
			background: white;
			border-radius: 16px;
			padding: 24px;
			box-shadow: 0 2px 16px rgba(0,0,0,0.06);
			border: 1px solid #F0F0F5;
		}

		/* ── Table ── */
		.table thead th {
			background: #F8F6FF;
			color: #8B47E8;
			font-size: 12px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.8px;
			border-bottom: none;
			padding: 12px;
		}

		.table tbody td {
			padding: 12px;
			vertical-align: middle;
			font-size: 13px;
			color: #444;
			border-bottom: 1px solid #F4F6FB;
		}

		.table tbody tr:hover {
			background: #FAFAFF;
		}

		.table tbody tr:last-child td {
			border-bottom: none;
		}

		/* ── Buttons ── */
		.btn-purple {
			background: linear-gradient(135deg, #6C22C9, #8B47E8);
			color: white;
			border: none;
			border-radius: 10px;
			padding: 8px 20px;
			font-weight: 600;
			font-size: 14px;
			box-shadow: 0 4px 12px rgba(108,34,201,0.3);
			transition: all 0.2s;
		}

			.btn-purple:hover {
				color: white;
				transform: translateY(-1px);
				box-shadow: 0 6px 16px rgba(108,34,201,0.4);
			}

		.btn-edit {
			background: #EEF2FF;
			color: #4338CA;
			border: none;
			padding: 5px 12px;
			border-radius: 8px;
			font-size: 12px;
			font-weight: 600;
		}

			.btn-edit:hover {
				background: #C7D2FE;
				color: #4338CA;
			}

		.btn-delete {
			background: #FEF2F2;
			color: #DC2626;
			border: none;
			padding: 5px 12px;
			border-radius: 8px;
			font-size: 12px;
			font-weight: 600;
		}

			.btn-delete:hover {
				background: #FECACA;
				color: #DC2626;
			}

		/* ── Badges ── */
		.badge-active {
			background: #D1FAE5;
			color: #065F46;
			padding: 4px 12px;
			border-radius: 20px;
			font-size: 11px;
			font-weight: 700;
		}

		.badge-inactive {
			background: #FEE2E2;
			color: #991B1B;
			padding: 4px 12px;
			border-radius: 20px;
			font-size: 11px;
			font-weight: 700;
		}

		.badge-scheduled {
			background: #DBEAFE;
			color: #1E40AF;
			padding: 4px 12px;
			border-radius: 20px;
			font-size: 11px;
			font-weight: 700;
		}

		.badge-available {
			background: #D1FAE5;
			color: #065F46;
			padding: 4px 12px;
			border-radius: 20px;
			font-size: 11px;
			font-weight: 700;
		}

		.badge-unavailable {
			background: #FEE2E2;
			color: #991B1B;
			padding: 4px 12px;
			border-radius: 20px;
			font-size: 11px;
			font-weight: 700;
		}

		/* ── Forms ── */
		.form-label {
			font-size: 13px;
			font-weight: 600;
			color: #444;
		}

		.form-control, .form-select {
			border: 2px solid #E8E8F0;
			border-radius: 10px;
			font-size: 14px;
			padding: 10px 14px;
		}

			.form-control:focus, .form-select:focus {
				border-color: #8B47E8;
				box-shadow: 0 0 0 3px rgba(139,71,232,0.1);
			}
	</style>

	@await RenderSectionAsync("Styles", required: false)
</head>

<body>
	<div style="display: flex; min-height: 100vh;">

		<!-- Sidebar -->
		<div class="sidebar">
			<a class="sidebar-brand" href="/Home/Get">
				<h5>🚂 Catering ERP</h5>
				<small>Railway Management System</small>
			</a>

			<nav class="sidebar-nav">
				<a href="/Home/Get" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")">
					<i class="bi bi-grid"></i> Dashboard
				</a>
				<a href="/Role/GetRole" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Roles" ? "active" : "")">
					<i class="bi bi-shield-lock"></i> Roles
				</a>
				<a href="/User/GetUser" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Users" ? "active" : "")">
					<i class="bi bi-people"></i> Users
				</a>
				<a href="/Train/Get" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Trains" ? "active" : "")">
					<i class="bi bi-train-front"></i> Trains
				</a>
				<a href="/Journey/Get" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Journeys" ? "active" : "")">
					<i class="bi bi-map"></i> Journeys
				</a>
				<a href="/MenuItem/GetMenuItem" class="nav-link @(ViewData["ActivePage"]?.ToString() == "MenuItems" ? "active" : "")">
					<i class="bi bi-egg-fried"></i> Menu Items
				</a>
				<a href="/Ingredient/Get" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Ingredients" ? "active" : "")">
					<i class="bi bi-basket"></i> Ingredients
				</a>
				<a href="/Order/Get" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Orders" ? "active" : "")">
					<i class="bi bi-receipt"></i> Orders
				</a>
				<a href="/InventoryLog/Get" class="nav-link @(ViewData["ActivePage"]?.ToString() == "InventoryLogs" ? "active" : "")">
					<i class="bi bi-journal-text"></i> Inventory Logs
				</a>
				<a href="/Report/Get" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Reports" ? "active" : "")">
					<i class="bi bi-bar-chart"></i> Reports
				</a>
			</nav>

			<div class="sidebar-footer">
				<div>Railway Catering ERP</div>
				<div>v1.0.0</div>
			</div>
		</div>

		<!-- Main Content -->
		<div class="main-wrapper">
			<div class="top-header">
				<h5>@ViewData["Title"]</h5>
				<div class="d-flex align-items-center gap-3">
					<span style="font-size:14px;">Super Admin</span>
					<a href="/Home/Logout" class="btn btn-sm btn-light fw-bold" style="border-radius:20px;">
						Logout →
					</a>
				</div>
			</div>

			<div class="content-area">
				@RenderBody()
			</div>
		</div>

	</div>

	<!-- Bootstrap JS -->
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>